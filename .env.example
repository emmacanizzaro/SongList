# =================== ENV VARS TEMPLATE ===================
# Copia este archivo como .env en apps/api y apps/web

# ---- DATABASE ----
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/songlist_db?schema=public"

# ---- JWT ----
JWT_SECRET="super-secret-jwt-key-change-in-production-min-32chars"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="super-secret-refresh-key-change-in-production-min-32chars"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ---- STRIPE ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_ENTERPRISE_MONTHLY="price_..."

# ---- MERCADO PAGO (alternativa a Stripe para LATAM) ----
MP_ACCESS_TOKEN="TEST-..."
MP_WEBHOOK_SECRET="..."

# ---- APP ----
API_PORT=3001
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:3001"
NODE_ENV="development"

# ---- REDIS (para cache y rate limiting - opcional) ----
REDIS_URL="redis://localhost:6379"

# ---- STORAGE (para logos y exports) ----
S3_BUCKET="songlist-assets"
S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."

# ---- NEXT.JS PUBLIC ----
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
