{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run db:generate && npm run build --workspace=@songlist/api"
  },
  "deploy": {
    "startCommand": "npm run start --workspace=@songlist/api",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
